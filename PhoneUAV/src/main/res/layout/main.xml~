<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="#101010"
    android:orientation="vertical" >

    <!-- set -->

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="3dip"
        android:layout_weight="1"
        android:background="#505050"
        android:descendantFocusability="beforeDescendants"
        android:focusableInTouchMode="true" >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:layout_margin="1dip"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/PeriodText"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="3"
                android:focusable="true"
                android:gravity="center|bottom"
                android:text="@string/period_label" >
            </TextView>

            <EditText
                android:id="@+id/PeriodValue"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:digits="0123456789"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:maxLines="1"
                android:numeric="integer"
                android:text="5" >
            </EditText>
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_margin="1dip"
            android:layout_weight="1"
            android:orientation="horizontal" >
        
        <Button
                android:id="@+id/PeriodButton"
                android:layout_width="42dp"
                android:layout_height="fill_parent"
                android:layout_margin="1dp"
                android:gravity="center" />
        <Button
                android:id="@+id/resetButton"
                android:layout_width="42dp"
                android:layout_height="fill_parent"
                android:layout_margin="1dp"
                android:gravity="center" />
        <Button
                android:id="@+id/photoButton"
                android:layout_width="42dp"
                android:layout_height="fill_parent"
                android:layout_margin="1dp"
                android:gravity="center" />
        <Button
                android:id="@+id/videoStartButton"
                android:layout_width="40dp"
                android:layout_height="fill_parent"
                android:layout_margin="1dp"
                android:gravity="center" />
        <Button
                android:id="@+id/videoStopButton"
                android:layout_width="40dp"
                android:layout_height="fill_parent"
                android:layout_margin="1dp"
                android:gravity="center" />
</LinearLayout>
        <TextureView
            android:id="@+id/preview"
            android:layout_width="65dip"
            android:layout_height="86dip"
            android:layout_marginRight="2dip"
            android:layout_marginTop="2dip"
            android:minHeight="32dip"
            android:minWidth="24dip"
            android:orientation="horizontal" />  
    </LinearLayout>
    <!-- 0 -->

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="3dip"
        android:layout_weight="1"
        android:background="#505050" >

        <TextView
            android:id="@+id/Channel0Text"
            android:layout_width="55dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="left"
            android:text="@string/channel0" >
        </TextView>

        <!--
            <TextView
                android:id="@+id/DutyCycle0label"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/duty_cycle" >
            </TextView>
        -->

        <TextView
            android:id="@+id/DutyCycle0Text"
            android:layout_width="34dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="right"
            android:text="0" />

        <SeekBar
            android:id="@+id/Channel0Seekbar"
            style="@style/CustomSlider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dip"
            android:layout_weight="4"
            android:gravity="center"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <!-- 1 -->

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="3dip"
        android:layout_weight="1"
        android:background="#505050" >

        <TextView
            android:id="@+id/Channel1Text"
            android:layout_width="55dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="left"
            android:text="@string/channel1" >
        </TextView>

        <!--
            <TextView
                android:id="@+id/DutyCycle1label"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/duty_cycle" >
            </TextView>
        -->

        <TextView
            android:id="@+id/DutyCycle1Text"
            android:layout_width="34dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="right"
            android:text="0" />

        <SeekBar
            android:id="@+id/Channel1Seekbar"
            style="@style/CustomSlider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dip"
            android:layout_weight="4"
            android:gravity="center"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <!-- 2 -->

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="3dip"
        android:layout_weight="1"
        android:background="#505050" >

        <TextView
            android:id="@+id/Channel2Text"
            android:layout_width="55dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="left"
            android:text="@string/channel2" >
        </TextView>

        <!--
            <TextView
                android:id="@+id/DutyCycle0label"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/duty_cycle" >
            </TextView>
        -->

        <TextView
            android:id="@+id/DutyCycle2Text"
            android:layout_width="34dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="right"
            android:text="0" />

        <SeekBar
            android:id="@+id/Channel2Seekbar"
            style="@style/CustomSlider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dip"
            android:layout_weight="4"
            android:gravity="center"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <!-- 3 -->

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="3dip"
        android:layout_weight="1"
        android:background="#505050" >

        <TextView
            android:id="@+id/Channel3Text"
            android:layout_width="55dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="left"
            android:text="@string/channel3" >
        </TextView>

        <!--
            <TextView
                android:id="@+id/DutyCycle3label"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/duty_cycle" >
            </TextView>
        -->

        <TextView
            android:id="@+id/DutyCycle3Text"
            android:layout_width="34dp"
            android:layout_height="fill_parent"
            android:layout_margin="3dip"
            android:gravity="right"
            android:text="0" />
        <SeekBar
            android:id="@+id/Channel3Seekbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dip"
            android:layout_weight="4"
            android:gravity="center"
            android:max="100"
            android:progress="0" />
    </LinearLayout>
    
<LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="3dip"
        android:layout_weight="1"
        android:background="#505050" >
    <Button
                android:id="@+id/ThrottleMinButton"
                android:layout_width="20dp"
                android:layout_height="fill_parent"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:gravity="center" />
    <Button
                android:id="@+id/ThrottleUpButton"
                android:layout_width="20dp"
                android:layout_height="fill_parent"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:gravity="center" /> 
    <Button
                android:id="@+id/ThrottleDownButton"
                android:layout_width="20dp"
                android:layout_height="fill_parent"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:gravity="center" />   
    <Button
                android:id="@+id/ThrottleMaxButton"
                android:layout_width="20dp"
                android:layout_height="fill_parent"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:gravity="center" />
</LinearLayout>

    <!-- server and sensor area -->

    <TableLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1" >

        <TableRow
            android:id="@+id/tableRow1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" >

            <TextView
                android:id="@+id/Axis0Label"
                android:layout_width="50dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="X:" >
            </TextView>

            <TextView
                android:id="@+id/Axis1Label"
                android:layout_width="50dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Y:" >
            </TextView>

            <TextView
                android:id="@+id/Axis2Label"
                android:layout_width="50dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Z:" >
            </TextView>

            <TextView
                android:id="@+id/Angle0Label"
                android:layout_width="50dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="pitch:" >
            </TextView>

            <TextView
                android:id="@+id/Angle1Label"
                android:layout_width="50dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="roll:" >
            </TextView>

            <TextView
                android:id="@+id/Angle2Label"
                android:layout_width="60dp"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="azimuth:" >
            </TextView>
        </TableRow>

        <TableRow
            android:id="@+id/tableRow2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" >

            <TextView
                android:id="@+id/Axis0Text"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" >
            </TextView>

            <TextView
                android:id="@+id/Axis1Text"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" >
            </TextView>

            <TextView
                android:id="@+id/Axis2Text"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" >
            </TextView>

            <TextView
                android:id="@+id/Angle0Text"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" >
            </TextView>

            <TextView
                android:id="@+id/Angle1Text"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" >
            </TextView>

            <TextView
                android:id="@+id/Angle2Text"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" >

                <!-- android:layout_gravity="center_horizontal" -->
            </TextView>
        </TableRow>

        <TableRow
            android:id="@+id/tableRow3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" >

            <TextView
                android:id="@+id/text_server"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_span="4" >
            </TextView>

            <CheckBox
                android:id="@+id/stabilisation_roll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="toggleStabiliseRoll"
                android:text="@string/symbol_stabilisation_roll"
                android:textSize="12sp" />

            <CheckBox
                android:id="@+id/stabilisation_pitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="toggleStabilisePitch"
                android:text="@string/symbol_stabilisation_pitch"
                android:textSize="12sp" />
        </TableRow>
    </TableLayout>

</LinearLayout>